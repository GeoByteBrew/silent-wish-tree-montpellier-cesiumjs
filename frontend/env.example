VITE_CESIUM_ION_TOKEN=
VITE_ION_PHOTOREALISTIC_ASSET_ID=

# If you only have an ion imagery asset (like 3830185), use this instead of the 3D Tiles asset id.
VITE_ION_IMAGERY_ASSET_ID=

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

VITE_TURNSTILE_SITE_KEY=

# Tree placement (optional overrides)
VITE_TREE_LAT=43.6113611111
VITE_TREE_LON=3.8695555556
# Legacy: absolute height above the ellipsoid (used only if photorealistic 3D tiles are NOT enabled)
VITE_TREE_HEIGHT=25

# Recommended: when photorealistic 3D tiles are enabled, the app samples the ground height and adds this offset (meters)
VITE_TREE_GROUND_OFFSET_M=1.5
VITE_TREE_GROUND_SAMPLE_RADIUS_M=6
VITE_TREE_SCALE=2
VITE_TREE_HEADING_DEG=0

# Optional: load the tree model and/or a GeoJSON point from Cesium ion instead of local files.
VITE_ION_TREE_ASSET_ID=
VITE_ION_TREE_GEOJSON_ASSET_ID=

# Optional: extra trees (one model + many point features from ion GeoJSON)
VITE_ION_EXTRA_TREES_MODEL_ASSET_ID=
VITE_ION_EXTRA_TREES_GEOJSON_ASSET_ID=
VITE_EXTRA_TREES_LIMIT=80
VITE_EXTRA_TREES_SCALE=1.2
VITE_EXTRA_TREES_GROUND_OFFSET_M=0.8
VITE_EXTRA_TREES_GROUND_SAMPLE_RADIUS_M=4
# If all extra trees are shifted consistently, fix drift here (meters in local ENU frame)
VITE_EXTRA_TREES_OFFSET_EAST_M=0
VITE_EXTRA_TREES_OFFSET_NORTH_M=0

# Camera focus (optional): override camera focus location
VITE_CAMERA_LAT=43.6119
VITE_CAMERA_LON=3.8730

# Camera start view (recommended for consistent initial framing)
VITE_CAMERA_START_LON=
VITE_CAMERA_START_LAT=
VITE_CAMERA_START_HEIGHT=
VITE_CAMERA_START_HEADING_DEG=
VITE_CAMERA_START_PITCH_DEG=
VITE_CAMERA_START_ROLL_DEG=

# Optional: "City" camera button preset
VITE_CAMERA_CITY_LON=
VITE_CAMERA_CITY_LAT=
VITE_CAMERA_CITY_HEIGHT=
VITE_CAMERA_CITY_HEADING_DEG=
VITE_CAMERA_CITY_PITCH_DEG=
VITE_CAMERA_CITY_ROLL_DEG=

# Tip: You can also set the start view in the app (Save start view), stored in localStorage (debug only).

# Optional: local testing for reveal endpoint only.
# Never set this in production.
VITE_DEMO_KEY=

# Optional: override reveal date for local testing only.
VITE_REVEAL_AT_ISO=2026-01-06T00:00:00+01:00
